# Database Configuration - Single PostgreSQL DB with schemas
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=YourStrong@Passw0rd
DB_NAME=SMI_DSS
DB_SCHEMA_NDS=nds
DB_SCHEMA_DDS=dds

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
API_TITLE=SS-MB-SMI Decision Support System
API_VERSION=1.0.0
API_PREFIX=/api/v1

# Optimization Configuration
DEFAULT_SOLVER=cbc
SOLVER_TIME_LIMIT=300
MIP_GAP=0.01

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Environment
ENVIRONMENT=development

# Frontend (Vite)
VITE_API_URL=/api/v1
